{
  "name": "reference-impl",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation of the order-pricing API",
  "type": "module",
  "exports": {
    ".": "./src/server.ts"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "openapi-types": "^12.1.0",
    "pino": "^9.6.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
