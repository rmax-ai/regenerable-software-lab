{
  "name": "regenerable-software-lab",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "description": "Experimental benchmark for evaluating whether AI coding agents can repeatedly generate software from durable, implementation-independent verification bundles",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.15.2"
    }
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.20.1",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
